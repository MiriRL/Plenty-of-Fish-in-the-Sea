  m_Name: More
  m_EditorClassIdentifier: Assembly-CSharp::Sentence
  id: More
  text: I mean, yeah. I think for me more so than others because I have a lot of
    work to do.
  nextSentence: {fileID: 0}
  options:
  - id: More1
    text: I feel that! Not all of the time, but I understand what you're getting
      at.
    nextSentence: {fileID: 11400000, guid: e4263f63b9ed14b529803dc935cb9315, type: 2}
    score: 2
    emotion: relaxed
  - id: More2
    text: Why don't you just quit then?
    nextSentence: {fileID: 11400000, guid: f6b37cd74d51d4ef7bdf78c93d54e6d0, type: 2}
    score: 0
    emotion: nervous
  - id: More3
    text: Alright, buddy, pack it up. Everybody has problems.
    nextSentence: {fileID: 11400000, guid: 299626e3f91d74e3092ccb4808fd5261, type: 2}
    score: -1
    emotion: panic
