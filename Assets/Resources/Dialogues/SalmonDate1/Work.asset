  m_Name: Work
  m_EditorClassIdentifier: Assembly-CSharp::Sentence
  id: Work
  text: I don't know, maybe you've got work or something? I don't know what people
    do!
  nextSentence: {fileID: 0}
  options:
  - id: Work1
    text: No, no, I'm just kidding. I'm delighted to be here!
    nextSentence: {fileID: 11400000, guid: 5866f6d98dd7248be86eebbdf97474a1, type: 2}
    score: 1
    emotion: neutral
  - id: Work2
    text: I mean, I just got here, I'm not super swamped.
    nextSentence: {fileID: 11400000, guid: 26c0684b966a74e0a8ac6cbca4beb9ab, type: 2}
    score: 0
    emotion: nervous
  - id: Work3
    text: Not for me! Work is for losers, I'm just here because I'm bored.
    nextSentence: {fileID: 11400000, guid: f5993f8668cae4a9ba3f1ceeedca736d, type: 2}
    score: -1
    emotion: stressed
