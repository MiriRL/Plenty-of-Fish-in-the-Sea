  m_Name: Offend
  m_EditorClassIdentifier: Assembly-CSharp::Sentence
  id: Offend
  text: I'm sorry, did I do something to offend you? You've been quite short with
    me so far.
  nextSentence: {fileID: 0}
  options:
  - id: Offend1
    text: No, I'm sorry, I must just be a little off today.
    nextSentence: {fileID: 11400000, guid: d930485f4924d48af831d7416169b08f, type: 2}
    score: 1
    emotion: happy
  - id: Offend2
    text: Um, yes! Does "stealing wallets" ring any bells?
    nextSentence: {fileID: 11400000, guid: e8a6a65da1fa84c1d9067dba9b1a4dc6, type: 2}
    score: 0
    emotion: despair
  - id: Offend3
    text: Offend me? No, I just don't like you!
    nextSentence: {fileID: 11400000, guid: a7d073262583e4bcc91830e898402fcd, type: 2}
    score: -1
