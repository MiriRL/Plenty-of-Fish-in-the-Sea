  m_Name: Hobbies
  m_EditorClassIdentifier: Assembly-CSharp::Sentence
  id: Hobbies
  text: Hooray! Well, now that the hard part's done, let's get to know each other
    a bit! What sorts of hobbies do you have?
  nextSentence: {fileID: 0}
  options:
  - id: Hobbies1
    text: Oh, I like lots of things, I'm not picky at all! What do you like to do?
    nextSentence: {fileID: 11400000, guid: cff2cffe43f364a2ca8be92042ffaf84, type: 2}
    onOptionSelected: {fileID: 0}
  - id: Hobbies2
    text: Uh, I like to swim.
    nextSentence: {fileID: 11400000, guid: 4372c41e7b5904031914f8e691ccf4f3, type: 2}
    onOptionSelected: {fileID: 0}
  - id: Hobbies3
    text: Hell no, I don't want to get to know you!
    nextSentence: {fileID: 11400000, guid: 74e0ca072b2c040b183906146bc2f57f, type: 2}
    onOptionSelected: {fileID: 0}
